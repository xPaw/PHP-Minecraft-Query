{
	"name": "xpaw/php-minecraft-query",
	"description": "PHP library to query Minecraft servers",
	"license": "MIT",
	"funding":
	[
        {
            "type": "github",
            "url": "https://github.com/sponsors/xPaw"
        }
	],
	"keywords":
	[
		"minecraft"
	],
	"require":
	{
		"php": ">=8.1"
	},
	"require-dev":
	{
		"phpstan/phpstan": "^2",
		"phpunit/phpunit": "^10",
		"vimeo/psalm": "^6"
	},
	"autoload":
	{
		"psr-4": { "xPaw\\": "src" }
	},
	"autoload-dev":
	{
		"psr-4": { "xPaw\\Tests\\": "tests" }
	},
	"archive":
	{
		"exclude":
		[
			"tests/",
			"phpstan.neon",
			"psalm.xml",
			"phpunit.xml"
		]
	}
}
